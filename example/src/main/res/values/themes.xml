<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GS805Example" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">#1976D2</item>
        <item name="colorPrimaryVariant">#004BA0</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FF6F00</item>
        <item name="colorSecondaryVariant">#C43E00</item>
        <item name="colorOnSecondary">#FFFFFF</item>
    </style>

    <style name="BtnStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">11sp</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BtnStyleSmall" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TabStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:minWidth">60dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
